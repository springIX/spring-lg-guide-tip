    <!-- footerDefault -->
    <c:import url="/WEB-INF/jsp/common/includes/footerDefault.jsp" charEncoding="utf-8" />
    <!-- // footerDefault -->
    <script>
      document.addEventListener("DOMContentLoaded", function () {
          const buttons = document.querySelectorAll(".sticky-inner-wrapper button");
          const contents = [document.getElementById("content1"), document.getElementById("content2"), document.getElementById("content3"), document.getElementById("content4")];
          const offset = 45; // 이동 시 상단 여백
      
          // 버튼 클릭 이벤트
          buttons.forEach((button, index) => {
              button.addEventListener("click", function () {
                  const targetPosition = contents[index].getBoundingClientRect().top + window.scrollY - offset;
      
                  // 스크롤 이동
                  window.scrollTo({
                      top: targetPosition,
                      behavior: "smooth",
                  });
      
                  // 활성화 업데이트
                  updateActiveButton(index);
              });
          });
      
          // 스크롤 이벤트로 활성화 상태 업데이트
          window.addEventListener("scroll", function () {
              const scrollPosition = window.scrollY + offset + 10; // 여유 공간 추가
      
              contents.forEach((content, index) => {
                  const contentTop = content.offsetTop;
                  const contentBottom = contentTop + content.offsetHeight;
      
                  if (scrollPosition >= contentTop && scrollPosition < contentBottom) {
                      updateActiveButton(index);
                  }
              });
          });
      
          // 활성화 상태 업데이트 함수
          function updateActiveButton(activeIndex) {
              buttons.forEach((button, index) => {
                  const activeBar = button.querySelector(".active-bar");
                  const pTag = button.querySelector("p");
      
                  if (index === activeIndex) {
                      // 활성화 스타일 적용
                      if (!activeBar) {
                          const newBar = document.createElement("div");
                          newBar.classList.add("absolute", "bottom-0", "left-0", "h-[3px]", "bg-blue-7", "active-bar");
                          newBar.style.width = "0%"; // 초기 너비 0%
                          newBar.style.transition = "width 0.3s ease"; // 트랜지션 추가
                          button.appendChild(newBar);
      
                          // 트랜지션을 위해 약간의 지연 후 너비를 100%로 설정
                          requestAnimationFrame(() => {
                              newBar.style.width = "100%";
                          });
                      }
      
                      if (pTag) {
                          pTag.classList.remove("text-gray-10", "font-medium");
                          pTag.classList.add("text-blue-7", "font-bold");
                      }
                  } else {
                      // 비활성화 스타일 적용
                      if (activeBar) activeBar.remove();
      
                      if (pTag) {
                          pTag.classList.remove("text-blue-7", "font-bold");
                          pTag.classList.add("text-gray-10", "font-medium");
                      }
                  }
              });
          }
      });
      </script>
